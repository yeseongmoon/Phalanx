{
  "name": "ntn-threat-flow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "6G NTN Threat-Flow Builder — React + TS front-end over the ENISA×SPARTA Algorithm 1 engine",
  "scripts": {
